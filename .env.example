# ============================================================================
# SiftRobust environment — copy to .env and fill in the provider(s) you want.
# ============================================================================

# Which provider to use by default. One of: anthropic, openai, google, groq.
# Only the chosen provider's key needs to be set; the others can stay blank.
LLM_PROVIDER=anthropic

# Optional model override. Empty means "use the provider's default_model"
# (claude-sonnet-4-6 for Anthropic, gpt-4o-mini for OpenAI, etc.)
# Setting this lets you A/B a different snapshot without touching code.
SIFT_MODEL=

# --- Provider API keys (only one is required) -------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# --- Gmail OAuth ------------------------------------------------------------
# Download the OAuth client JSON from the Google Cloud Console and point
# this at it. Scope used: https://www.googleapis.com/auth/gmail.modify
# (read + write + send + label — one token covers every action the app takes.)
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# --- Local cache ------------------------------------------------------------
# SQLite file that caches classifications, drafts, and voice profiles so
# repeated runs over the same threads are near-free. Safe to delete; it
# regenerates on next run.
SIFT_DB=./sift.db
